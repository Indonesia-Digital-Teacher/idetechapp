GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Disarankan diisi juga saat production agar callback Google stabil di domain custom.
GOOGLE_REDIRECT_URI=https://idetech.example.com/api/auth/google/callback

# MariaDB connection (format: mysql://user:pass@host:port/database)
DATABASE_URL=mysql://idetech:idetech_secret@localhost:3306/idetech

# MariaDB credentials untuk docker-compose (opsional jika sudah pakai DATABASE_URL lengkap)
MYSQL_ROOT_PASSWORD=idetech_root_secret
MYSQL_DATABASE=idetech
MYSQL_USER=idetech
MYSQL_PASSWORD=idetech_secret

# S3/RustFS object storage
RUSTFS_ENDPOINT=https://s3.example.com
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY=your-access-key
RUSTFS_SECRET_KEY=your-secret-key
RUSTFS_PUBLIC_BASE_URL=https://cdn.example.com/idetech-assets

# AI chat assistant
CYBRA_API_URL=https://cybrabot.example.com

# Demo login (hanya aktif di non-production kecuali diaktifkan secara eksplisit)
# DEMO_LOGIN_ENABLED=true
