{
  "name": "idetechapp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run server:dev & bun run client:dev",
    "client:dev": "vite --host 0.0.0.0 --port 2016",
    "server:dev": "PORT=2017 bun --watch src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "bun src/server/index.ts",
    "db:seed": "bun src/server/seed.ts",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@hono/node-server": "^1.13.8",
    "@vitejs/plugin-react": "^4.3.4",
    "clsx": "^2.1.1",
    "driver.js": "^1.6.0",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.6.15",
    "mysql2": "^3.11.0",
    "katex": "^0.17.0",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-player": "^2.16.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/bun": "^1.1.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vite-plugin-pwa": "^1.3.0"
  }
}
