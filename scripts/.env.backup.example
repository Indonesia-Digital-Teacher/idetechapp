# =============================================================================
# IdeTech - Konfigurasi Backup Database
# Salin file ini ke .env.backup dan isi nilainya
# JANGAN commit file .env.backup ke git!
# =============================================================================

# ---- MariaDB / Docker -------------------------------------------------------
# Nama container MariaDB di Docker
BACKUP_CONTAINER_NAME=idetech_mariadb

# Nama database yang dibackup
BACKUP_DB_NAME=idetech

# Password root MariaDB (sama dengan MYSQL_ROOT_PASSWORD di .env)
BACKUP_DB_ROOT_PASS=idetech_root_secret

# ---- Penyimpanan Lokal -------------------------------------------------------
# Direktori lokal untuk menyimpan file backup sementara
BACKUP_DIR=/home/ferilee/backup_db

# Berapa hari menyimpan backup lokal sebelum dihapus
BACKUP_RETAIN_DAYS=7

# ---- Telegram ----------------------------------------------------------------
# Token bot Telegram (dari @BotFather)
# Format: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID tujuan notifikasi (bisa personal, group, atau channel)
# Cara dapat: kirim pesan ke bot, lalu buka:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# ---- Google Drive (rclone) ---------------------------------------------------
# Aktifkan/nonaktifkan upload ke Google Drive
RCLONE_ENABLED=true

# Nama remote rclone yang sudah dikonfigurasi (lihat: rclone listremotes)
RCLONE_REMOTE=gdrive

# Path folder tujuan di Google Drive
RCLONE_BACKUP_PATH=IdeTech/database-backups
